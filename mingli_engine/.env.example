# ===========================================
# MingLi Engine - LLM Configuration
# ===========================================
# Copy this file to .env and fill in your API keys.
# You can also configure via Web UI (gear icon).
# ===========================================

# LLM Provider: deepseek | qwen | glm | kimi | wenxin | openai | claude | ollama | custom
LLM_PROVIDER=deepseek

# ── Domestic LLMs (Recommended) ──

# DeepSeek (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=

# Tongyi Qwen (https://dashscope.console.aliyun.com/apiKey)
QWEN_API_KEY=

# Zhipu GLM (https://open.bigmodel.cn/usercenter/apikeys)
GLM_API_KEY=

# Kimi / Moonshot (https://platform.moonshot.cn/console/api-keys)
KIMI_API_KEY=

# Baidu Wenxin (https://cloud.baidu.com/product/wenxinworkshop)
# Format: API_KEY:SECRET_KEY
WENXIN_API_KEY=

# ── International LLMs ──

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Claude / Anthropic (https://console.anthropic.com/settings/keys)
CLAUDE_API_KEY=

# ── Ollama (Local, no key needed) ──
OLLAMA_BASE_URL=http://localhost:11434

# ── Custom OpenAI-compatible API ──
CUSTOM_API_URL=
CUSTOM_API_KEY=
CUSTOM_MODEL=
